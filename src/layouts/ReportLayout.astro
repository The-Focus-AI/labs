---
import BaseLayout from './BaseLayout.astro';

interface Props {
  pageTitle: string;
  description?: string;
  bodyClass?: string;
  openGraphImage?: string;
}

const {
  pageTitle,
  description = 'Research measurements from TheFocus.AI Labs.',
  bodyClass = '',
  openGraphImage,
} = Astro.props;

const site = Astro.site ?? new URL('https://labs.thefocus.ai');
const ogUrl = openGraphImage
  ? new URL(openGraphImage, site).href
  : new URL('/favicon.svg', site).href;
---
<BaseLayout title={pageTitle} description={description} theme="ledger" bodyClass={bodyClass}>
  <Fragment slot="head">
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogUrl} />
    <meta name="twitter:card" content="summary_large_image" />
  </Fragment>
  <slot />
</BaseLayout>
