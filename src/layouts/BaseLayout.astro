---
import '../styles/global.css';
import NewsletterPopup from '../components/NewsletterPopup.astro';

interface Props {
  title: string;
  description?: string;
  theme?: 'ledger' | 'magazine';
}

const {
  title,
  description = 'TheFocus.AI Labs — thoughts, reports, recipes, and publication issues from the front of AI engineering.',
  theme = 'ledger',
} = Astro.props;
---
<!doctype html>
<html lang="en" data-theme={theme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Inter:wght@400;500;600;700;900&family=Courier+Prime:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <a href="/" class="wordmark" aria-label="TheFocus.AI Labs">
          {theme === 'ledger' ? (
            <>
              <span class="wordmark-glyph" aria-hidden="true"></span>
              <span class="wordmark-text">TheFocus</span>
              <span class="wordmark-sub">Labs</span>
            </>
          ) : (
            <>
              <span class="wordmark-block" aria-hidden="true"></span>
              <span class="wordmark-text">THEFOCUS.AI</span>
              <span class="wordmark-divider" aria-hidden="true">·</span>
              <span class="wordmark-sub">MAGAZINE</span>
            </>
          )}
        </a>
        <nav class="site-nav" aria-label="Primary">
          {theme === 'ledger' ? (
            <>
              <a href="/dispatch/">Dispatch</a>
              <a href="/quarterly/">How AI</a>
              <a href="/reports/">Measurements</a>
              <a href="/recipes/">Bench</a>
              <a href="/issues/">Issues</a>
            </>
          ) : (
            <a href="/">← Labs</a>
          )}
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer-inner">
        <span>Published by <a href="https://thefocus.ai">TheFocus.AI</a></span>
        <span>
          <a href="https://courses.thefocus.ai">Courses</a>
          ·
          <a href="https://standards.thefocus.ai">Standards</a>
          ·
          <a href="https://github.com/The-Focus-AI/labs">Source</a>
        </span>
      </div>
    </footer>

    {theme === 'ledger' && <NewsletterPopup />}
  </body>
</html>
