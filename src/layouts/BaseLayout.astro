---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import NewsletterPopup from '../components/NewsletterPopup.astro';

interface Props {
  title: string;
  description?: string;
  theme?: 'ledger' | 'magazine';
  bodyClass?: string;
}

const {
  title,
  description = 'TheFocus.AI Labs — dispatch, measurements, bench recipes, and publication issues from the front of AI engineering.',
  theme = 'ledger',
  bodyClass = '',
} = Astro.props;
---
<!doctype html>
<html lang="en" data-theme={theme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Inter:wght@400;500;600;700;900&family=Courier+Prime:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body class:list={[bodyClass]}>
    <SiteHeader theme={theme} />

    <main>
      <slot />
    </main>

    <SiteFooter theme={theme} />

    {theme === 'ledger' && <NewsletterPopup />}
  </body>
</html>
