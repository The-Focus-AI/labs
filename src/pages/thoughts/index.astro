---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getThoughts, getThoughtPath } from '../../lib/thoughts';

const thoughts = await getThoughts();

const cardImages = await import.meta.glob<{ default: { src: string } }>(
  '/src/content/assets/cards/*.{jpeg,jpg,png,gif,webp}'
);

function cardSrc(image?: string) {
  if (!image) return null;
  const key = `/src/content/assets/cards/${image}`;
  const mod = cardImages[key];
  return mod ? mod().then((m) => m.default.src) : null;
}

const withImages = await Promise.all(
  thoughts.map(async (thought) => ({
    thought,
    imageSrc: thought.data.image ? await cardSrc(thought.data.image) : null,
  }))
);
---
<BaseLayout title="Thoughts · TheFocus.AI Labs" description="Essays and field notes on AI engineering from TheFocus.AI Labs.">
  <section class="hub">
    <div class="hub-inner">
      <p class="section-label">Thoughts</p>
      <h1 class="hub-title">Field notes from the workshop.</h1>
      <p class="hub-lead">
        Essays, comparisons, and working notes — what we're seeing, building, and
        testing. Published irregularly.
      </p>

      <ul class="hub-grid">
        {withImages.map(({ thought, imageSrc }) => (
          <li>
            <a class="content-card" href={getThoughtPath(thought)}>
              {imageSrc && (
                <img class="card-thumb" src={imageSrc} alt="" loading="lazy" />
              )}
              <p class="mono-label">
                {thought.data.date.toLocaleDateString('en-US', {
                  month: 'short',
                  year: 'numeric',
                })}
              </p>
              <h2>{thought.data.title}</h2>
              {thought.data.description && <p>{thought.data.description}</p>}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .hub {
    padding: var(--section-y) 0;
  }

  .hub-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  .hub-title {
    font-size: clamp(2rem, 5vw, 3.75rem);
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--text-strong);
    margin: 0.75rem 0 1rem;
    max-width: 16ch;
  }

  .hub-lead {
    font-size: 20px;
    line-height: 1.5;
    color: var(--text-2);
    max-width: 52ch;
    margin: 0 0 3rem;
  }

  .hub-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .hub-grid li {
    background: var(--canvas);
  }

  .card-thumb {
    width: 100%;
    height: 160px;
    object-fit: cover;
    display: block;
    margin: calc(var(--card-pad) * -1);
    margin-bottom: 1rem;
    width: calc(100% + var(--card-pad) * 2);
    border-bottom: 1px solid var(--border);
  }
</style>
