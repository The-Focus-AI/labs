---
import { getThoughts, getThoughtSlug, getThoughtPath } from '../../lib/thoughts';

export async function getStaticPaths() {
  const thoughts = await getThoughts();
  return thoughts
    .filter((t) => t.data.column !== 'ephemeral')
    .map((thought) => ({
      params: { slug: getThoughtSlug(thought) },
      props: { target: getThoughtPath(thought) },
    }));
}

const { target } = Astro.props;
return Astro.redirect(target, 301);
---
