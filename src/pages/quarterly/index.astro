---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getQuarterlyPosts, getThoughtPath } from '../../lib/thoughts';
import { HOW_AI } from '../../lib/taxonomy';

const posts = await getQuarterlyPosts();

const cardImages = await import.meta.glob<{ default: { src: string } }>(
  '/src/content/assets/cards/*.{jpeg,jpg,png,gif,webp}'
);

async function cardSrc(image?: string) {
  if (!image) return null;
  const key = `/src/content/assets/cards/${image}`;
  const mod = cardImages[key];
  return mod ? (await mod()).default.src : null;
}

const withImages = await Promise.all(
  posts.map(async (thought) => ({
    thought,
    imageSrc: thought.data.image ? await cardSrc(thought.data.image) : null,
  }))
);
---
<BaseLayout
  title="How AI · TheFocus.AI Labs"
  description="Monthly operational snapshots — models, harness, process, what changed."
>
  <section class="hub">
    <div class="hub-inner">
      <p class="section-label">How AI</p>
      <h1 class="hub-title">Operational snapshots.</h1>
      <p class="hub-lead">
        One edition per month — a fixed frame covering how we use AI for work, code,
        operations, and life. These roll up the weekly dispatches into something you
        can print, archive, or hand to a team.
      </p>

      <div class="series-header">
        <h2 class="section-label">{HOW_AI.label}</h2>
        <p>{HOW_AI.description}</p>
        <ul class="series-sections mono-label">
          {HOW_AI.sections.map((s) => <li>{s}</li>)}
        </ul>
      </div>

      <ul class="post-list">
        {withImages.map(({ thought, imageSrc }) => (
          <li>
            <a class="content-card series-card" href={getThoughtPath(thought)}>
              {imageSrc && <img class="card-thumb" src={imageSrc} alt="" loading="lazy" />}
              <p class="mono-label">
                {thought.data.date.toLocaleDateString('en-US', {
                  month: 'long',
                  year: 'numeric',
                })}
              </p>
              <h3>{thought.data.title}</h3>
              {thought.data.description && <p>{thought.data.description}</p>}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .hub { padding: var(--section-y) 0; }
  .hub-inner { max-width: var(--container-max); margin: 0 auto; padding: 0 var(--gutter); }
  .hub-title {
    font-size: clamp(2rem, 5vw, 3.75rem);
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--text-strong);
    margin: 0.75rem 0 1rem;
    max-width: 16ch;
  }
  .hub-lead {
    font-size: 20px; line-height: 1.5; color: var(--text-2);
    max-width: 58ch; margin: 0 0 2.5rem;
  }
  .series-header { margin-bottom: 2rem; max-width: 58ch; }
  .series-header p { color: var(--text-2); margin: 0.75rem 0 1rem; line-height: 1.5; }
  .series-sections {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-wrap: wrap; gap: 0.5rem 1rem; color: var(--muted);
  }
  .post-list {
    list-style: none; margin: 0; padding: 0;
    display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1px; background: var(--border); border: 1px solid var(--border);
  }
  .post-list li { background: var(--canvas); }
  .series-card h3 { font-size: 20px; font-weight: 500; color: var(--text-strong); margin: 0.35rem 0 0.75rem; }
  .card-thumb {
    width: calc(100% + var(--card-pad) * 2); height: 160px; object-fit: cover;
    display: block; margin: calc(var(--card-pad) * -1); margin-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }
</style>
