---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import EmailSignup from '../components/EmailSignup.astro';
import {
  getDispatches,
  getQuarterlyPosts,
  getThoughtPath,
} from '../lib/thoughts';
import { PILLARS, type Pillar } from '../lib/taxonomy';

const allIssues = await getCollection('issues');
const issues = allIssues
  .filter((i) => !i.data.draft)
  .sort((a, b) => b.data.published.getTime() - a.data.published.getTime());

const featuredIssue = issues.find((i) => i.data.vertical === 'state') ?? issues[0];
const latestQuarterly = (await getQuarterlyPosts())[0];
const recentDispatches = (await getDispatches()).slice(0, 5);

const verticalLabel: Record<string, string> = {
  state: 'STATE',
  surface: 'SURFACE',
  runtime: 'RUNTIME',
  harness: 'HARNESS',
  local: 'LOCAL',
  wire: 'WIRE',
};

const measurements = [
  {
    label: 'RM-2026-05-LP',
    title: 'Local Providers',
    href: '/reports/local-providers/',
  },
  {
    label: 'RM-2026-03-MS',
    title: 'Model Showdown',
    href: '/reports/model-showdown/',
  },
  {
    label: 'RM-2026-02-CW',
    title: 'Car Wash Test',
    href: '/reports/car-wash-test/',
  },
];
---
<BaseLayout title="TheFocus.AI Labs">
  <section class="hero ledger-grid">
    <div class="hero-inner">
      <p class="section-label">TheFocus.AI Labs</p>
      <h1>Building intelligent organizations.</h1>
      <p class="hero-lead">
        We teach teams to use AI, build habitats and integrations, deploy in production,
        and measure what works. Labs is the workshop floor — weekly dispatches, quarterly
        snapshots, evidence, and the publication line.
      </p>
      <div class="hero-actions">
        <a class="btn-primary" href="/dispatch/">Read dispatch</a>
        <a class="btn-ghost" href="/quarterly/">How AI snapshots</a>
      </div>
    </div>
  </section>

  <section class="cadence">
    <div class="cadence-inner">
      <p class="section-label">Publishing cadence</p>
      <div class="cadence-grid">
        <div class="cadence-card">
          <span class="mono-label">Weekly</span>
          <h2>Dispatch</h2>
          <p>1–2 field notes per week. Small observations, experiments, and client patterns.</p>
          <a class="mono-label" href="/dispatch/">Browse dispatch →</a>
        </div>
        <div class="cadence-card">
          <span class="mono-label">Monthly</span>
          <h2>How AI</h2>
          <p>Fixed-frame operational snapshots — models, harness, process, what changed.</p>
          <a class="mono-label" href="/quarterly/">Read How AI →</a>
        </div>
        <div class="cadence-card">
          <span class="mono-label">Evidence</span>
          <h2>Measurements</h2>
          <p>Interactive evals and field studies with real data and doc numbers.</p>
          <a class="mono-label" href="/reports/">Browse measurements →</a>
        </div>
        <div class="cadence-card">
          <span class="mono-label">Archive</span>
          <h2>Issues &amp; print</h2>
          <p>Curated magazine issues — roll-ups you can print as the record of a year.</p>
          <a class="mono-label" href="/issues/">Publication line →</a>
        </div>
      </div>
    </div>
  </section>

  <section class="pillars">
    <div class="pillars-inner">
      <p class="section-label">Six pillars</p>
      <div class="pillars-grid">
        {(Object.entries(PILLARS) as [Pillar, (typeof PILLARS)[Pillar]][]).map(([key, p]) => (
          <a class="pillar-card" href={`/dispatch/${key}/`}>
            <span class="mono-label">{p.label}</span>
            <h2>{p.title}</h2>
            <p>{p.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  {latestQuarterly && (
    <section class="featured-block">
      <div class="featured-inner">
        <div class="block-header">
          <p class="section-label">Latest How AI</p>
          <a class="mono-label" href="/quarterly/">All editions →</a>
        </div>
        <a class="content-card featured-card" href={getThoughtPath(latestQuarterly)}>
          <p class="mono-label">
            {latestQuarterly.data.date.toLocaleDateString('en-US', {
              month: 'long',
              year: 'numeric',
            })}
          </p>
          <h2>{latestQuarterly.data.title}</h2>
          <p>{latestQuarterly.data.description}</p>
        </a>
      </div>
    </section>
  )}

  <section class="featured-block">
    <div class="featured-inner">
      <div class="block-header">
        <p class="section-label">Recent measurements</p>
        <a class="mono-label" href="/reports/">All measurements →</a>
      </div>
      <ul class="measure-list">
        {measurements.map((m) => (
          <li>
            <a href={m.href}>
              <span class="mono-label">{m.label}</span>
              <span>{m.title}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {featuredIssue && (
    <section class="featured-block">
      <div class="featured-inner">
        <div class="block-header">
          <p class="section-label">Latest issue</p>
          <a class="mono-label" href="/issues/">All issues →</a>
        </div>
        <a class="content-card featured-card" href={`/${featuredIssue.slug}/`}>
          <p class="mono-label">
            {verticalLabel[featuredIssue.data.vertical]} · №{' '}
            {String(featuredIssue.data.issue_number).padStart(2, '0')}
          </p>
          <h2>{featuredIssue.data.issue_title}</h2>
          <p>{featuredIssue.data.subtitle}</p>
        </a>
      </div>
    </section>
  )}

  {recentDispatches.length > 0 && (
    <section class="featured-block">
      <div class="featured-inner">
        <div class="block-header">
          <p class="section-label">Recent dispatch</p>
          <a class="mono-label" href="/dispatch/">All dispatch →</a>
        </div>
        <ul class="measure-list">
          {recentDispatches.map((thought) => (
            <li>
              <a href={getThoughtPath(thought)}>
                <span class="mono-label">{PILLARS[thought.data.pillar].label}</span>
                <span>{thought.data.title}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <EmailSignup
    heading="Get the dispatch."
    blurb="Weekly notes and quarterly snapshots. No marketing."
  />
</BaseLayout>

<style>
  .hero {
    padding: 5rem 0 4rem;
    border-bottom: 1px solid var(--border);
  }

  .hero-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  h1 {
    font-size: clamp(2.25rem, 6vw, 3.75rem);
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--text-strong);
    margin: 0.75rem 0 1.25rem;
    max-width: 14ch;
  }

  .hero-lead {
    font-size: 20px;
    line-height: 1.5;
    color: var(--text-2);
    max-width: 58ch;
    margin: 0 0 2rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .cadence,
  .pillars,
  .featured-block {
    padding: var(--section-y) 0;
    border-bottom: 1px solid var(--border);
  }

  .cadence-inner,
  .pillars-inner,
  .featured-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  .cadence-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    margin-top: 1.5rem;
  }

  .cadence-card {
    background: var(--surface);
    padding: var(--card-pad);
  }

  .cadence-card h2 {
    font-size: 20px;
    font-weight: 500;
    color: var(--text-strong);
    margin: 0.5rem 0 0.75rem;
  }

  .cadence-card p {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.6;
    margin: 0 0 1.25rem;
  }

  .cadence-card a {
    color: var(--signal);
    text-decoration: none;
  }

  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    margin-top: 1.5rem;
  }

  .pillar-card {
    background: var(--surface);
    padding: var(--card-pad);
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .pillar-card:hover {
    background: color-mix(in srgb, var(--surface) 92%, white);
  }

  .pillar-card h2 {
    font-size: 18px;
    font-weight: 500;
    color: var(--text-strong);
    margin: 0.5rem 0 0.75rem;
  }

  .pillar-card p {
    font-size: 14px;
    color: var(--muted);
    margin: 0;
    line-height: 1.6;
  }

  .block-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .block-header a {
    text-decoration: none;
    color: var(--signal);
  }

  .featured-card h2 {
    margin-top: 0.5rem;
  }

  .measure-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border: 1px solid var(--border);
  }

  .measure-list li + li {
    border-top: 1px solid var(--border);
  }

  .measure-list a {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 1.5rem;
    padding: 1rem 1.25rem;
    text-decoration: none;
    color: var(--text);
    background: var(--surface);
  }

  .measure-list a:hover {
    color: var(--text-strong);
    background: color-mix(in srgb, var(--surface) 90%, white);
  }

  @media (max-width: 640px) {
    .measure-list a {
      grid-template-columns: 1fr;
      gap: 0.35rem;
    }
  }
</style>
