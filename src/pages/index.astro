---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import EmailSignup from '../components/EmailSignup.astro';
import { getThoughts, getThoughtPath } from '../lib/thoughts';

const allIssues = await getCollection('issues');
const issues = allIssues
  .filter((i) => !i.data.draft)
  .sort((a, b) => b.data.published.getTime() - a.data.published.getTime());

const featuredIssue = issues.find((i) => i.data.vertical === 'state') ?? issues[0];
const recentThoughts = (await getThoughts()).slice(0, 4);

const verticalLabel: Record<string, string> = {
  state: 'STATE',
  surface: 'SURFACE',
  runtime: 'RUNTIME',
  harness: 'HARNESS',
  local: 'LOCAL',
  wire: 'WIRE',
};
---
<BaseLayout title="TheFocus.AI Labs">
  <section class="hero ledger-grid">
    <div class="hero-inner">
      <p class="section-label">TheFocus.AI Labs</p>
      <h1>Field reports from the front of AI engineering.</h1>
      <p class="hero-lead">
        Thoughts, interactive reports, recipes, and publication issues — for people
        who build for a living.
      </p>
      <div class="hero-actions">
        <a class="btn-primary" href="/thoughts/">Read thoughts</a>
        <a class="btn-ghost" href="/reports/">Browse reports</a>
      </div>
    </div>
  </section>

  <section class="lanes">
    <div class="lanes-inner">
      <a class="lane-card" href="/thoughts/">
        <span class="mono-label">01 — THOUGHTS</span>
        <h2>Essays and working notes</h2>
        <p>What we're seeing, building, and testing in the open.</p>
      </a>
      <a class="lane-card" href="/reports/">
        <span class="mono-label">02 — REPORTS</span>
        <h2>Interactive research</h2>
        <p>Model evals, benchmarks, and field studies with real data.</p>
      </a>
      <a class="lane-card" href="/recipes/">
        <span class="mono-label">03 — RECIPES</span>
        <h2>Weekend projects</h2>
        <p>Agents, tools, prompts — build it yourself in one sitting.</p>
      </a>
      <a class="lane-card" href="/issues/">
        <span class="mono-label">04 — ISSUES</span>
        <h2>Publication line</h2>
        <p>STATE, SURFACE, RUNTIME — six verticals, irregular issues.</p>
      </a>
    </div>
  </section>

  {featuredIssue && (
    <section class="featured">
      <div class="featured-inner">
        <p class="section-label">Latest issue</p>
        <a class="content-card featured-card" href={`/${featuredIssue.slug}/`}>
          <p class="mono-label">
            {verticalLabel[featuredIssue.data.vertical]} · №{' '}
            {String(featuredIssue.data.issue_number).padStart(2, '0')}
          </p>
          <h2>{featuredIssue.data.issue_title}</h2>
          <p>{featuredIssue.data.subtitle}</p>
        </a>
      </div>
    </section>
  )}

  {recentThoughts.length > 0 && (
    <section class="recent">
      <div class="recent-inner">
        <div class="recent-header">
          <p class="section-label">Recent thoughts</p>
          <a class="mono-label" href="/thoughts/">View all →</a>
        </div>
        <ul class="recent-list">
          {recentThoughts.map((thought) => (
            <li>
              <a href={getThoughtPath(thought)}>
                <span class="mono-label">
                  {thought.data.date.toLocaleDateString('en-US', {
                    month: 'short',
                    year: 'numeric',
                  })}
                </span>
                <span>{thought.data.title}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <EmailSignup
    heading="Get the dispatch."
    blurb="One email when new issues and reports ship. No marketing."
  />
</BaseLayout>

<style>
  .hero {
    padding: 5rem 0 4rem;
    border-bottom: 1px solid var(--border);
  }

  .hero-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  h1 {
    font-size: clamp(2.25rem, 6vw, 3.75rem);
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--text-strong);
    margin: 0.75rem 0 1.25rem;
    max-width: 16ch;
  }

  .hero-lead {
    font-size: 20px;
    line-height: 1.5;
    color: var(--text-2);
    max-width: 52ch;
    margin: 0 0 2rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .lanes {
    padding: var(--section-y) 0;
    border-bottom: 1px solid var(--border);
  }

  .lanes-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--gutter);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .lane-card {
    background: var(--surface);
    padding: var(--card-pad);
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .lane-card:hover {
    background: color-mix(in srgb, var(--surface) 92%, white);
  }

  .lane-card h2 {
    font-size: 20px;
    font-weight: 500;
    color: var(--text-strong);
    margin: 0.5rem 0 0.75rem;
  }

  .lane-card p {
    font-size: 14px;
    color: var(--muted);
    margin: 0;
    line-height: 1.6;
  }

  .featured,
  .recent {
    padding: var(--section-y) 0;
  }

  .featured-inner,
  .recent-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  .featured-card h2 {
    margin-top: 0.5rem;
  }

  .recent-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .recent-header a {
    text-decoration: none;
    color: var(--signal);
  }

  .recent-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border: 1px solid var(--border);
  }

  .recent-list li + li {
    border-top: 1px solid var(--border);
  }

  .recent-list a {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 1.5rem;
    padding: 1rem 1.25rem;
    text-decoration: none;
    color: var(--text);
    background: var(--surface);
  }

  .recent-list a:hover {
    color: var(--text-strong);
    background: color-mix(in srgb, var(--surface) 90%, white);
  }

  @media (max-width: 640px) {
    .recent-list a {
      grid-template-columns: 1fr;
      gap: 0.35rem;
    }
  }
</style>
